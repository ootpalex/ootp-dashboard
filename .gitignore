# Dependencies
app/node_modules/

# Build output
app/dist/

# Generated data (re-create via: python3 run.py)
app/public/data/

# Python
model/__pycache__/
model/src/__pycache__/
model/src/aggregators/__pycache__/
model/tests/__pycache__/
*.pyc
__pycache__/
.pytest_cache/

# Per-league generated artifacts (regenerated by the pipeline on each run).
# League inputs (league.json, csv/, metadata/) ARE checked in so CI runs the
# full test suite against real fixtures — see CHANGELOG v0.1.1.
leagues/*/output/*
leagues/*/metadata/.metadata_cache.json

# OOTP regression cache (auto-generated alongside the calibration CSVs, which
# DO ship — they're per-OOTP-version baseline data, not user-specific)
data/regressions/*/.regressions_cache.json

# Legacy single-league paths (pre-v0.1.0 restructure; still gitignored so
# anyone running an old version doesn't accidentally commit user data)
model/data/players/
model/data/regressions/
model/data/metadata/
model/data/relative/
model/data/ballparks.csv
model/*.xlsx
model/pipeline_settings.json

# Claude Code harness (local AI tooling, not for upload)
.claude/

# OS
.DS_Store

# IDE
.vscode/
.idea/
